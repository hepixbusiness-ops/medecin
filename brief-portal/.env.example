# URL publique du site (canonical, OG tags)
NEXT_PUBLIC_SITE_URL=https://brief.votre-agence.com

# Supabase — projet utilisé pour stocker les dossiers et les fichiers
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=votre-cle-service-role

# Webhook n8n déclenché à chaque soumission (création dossier Drive,
# page Notion, email de notification à l'agence)
N8N_WEBHOOK_URL=https://votre-instance-n8n.example.com/webhook/brief-client
