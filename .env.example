# === Facebook ===
FB_PAGE_ID=                    # ID numérique de la Page Facebook ProRDV (voir README, section Facebook)
FB_PAGE_ACCESS_TOKEN=          # Token de Page longue durée avec la permission pages_manage_posts (voir README)
GRAPH_API_VERSION=v21.0        # Version de la Graph API utilisée pour tous les appels Facebook

# === Airtable (état + historique anti-répétition) ===
AIRTABLE_API_KEY=              # Personal Access Token Airtable (scopes data.records:read + data.records:write)
AIRTABLE_BASE_ID=              # ID de la base Airtable (commence par "app...")
AIRTABLE_TABLE_NAME=Facebook Posts   # Nom de la table dans la base (optionnel, défaut "Facebook Posts")

# === Génération de contenu (légende) ===
CONTENT_MODE=template          # "template" (gratuit, gabarits locaux) ou "ai" (légende rédigée par Anthropic)
ANTHROPIC_API_KEY=             # Requis uniquement si CONTENT_MODE=ai
ANTHROPIC_MODEL=claude-sonnet-5   # Optionnel, modèle Anthropic utilisé si CONTENT_MODE=ai (défaut : claude-sonnet-5)

# === Génération d'image ===
IMAGE_PROVIDER=banque          # "openai" | "ideogram" | "banque" (pioche dans /assets/banque, aucune clé requise)
OPENAI_API_KEY=                # Requis uniquement si IMAGE_PROVIDER=openai
IDEOGRAM_API_KEY=              # Requis uniquement si IMAGE_PROVIDER=ideogram

# === Alerte en cas d'échec (optionnel) ===
N8N_ALERT_WEBHOOK_URL=         # URL de webhook n8n ; si vide, l'échec est simplement loggé en console
